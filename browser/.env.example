VITE_NETWORK_ID=preprod
# 1AM users: leave VITE_PROOF_SERVER_URL unset — proving goes wallet → ProofStation (api-preprod.1am.xyz).
# Lace / local dev only: run Docker proof-server and set:
# VITE_PROOF_SERVER_URL=http://localhost:6300
# Optional — host ZK keys on a CDN instead of the DApp origin (see DEPLOY.md):
# VITE_ZK_CONFIG_BASE_URL=https://your-cdn.example.com/por-zk
# Optional: join an existing contract instead of deploying fresh
# VITE_DEFAULT_CONTRACT=
