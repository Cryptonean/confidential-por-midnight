{
  "name": "confidential-por-midnight",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Confidential Proof of Reserves — Midnight Compact circuit (Level 1) + Lace browser DApp (Level 2)",
  "engines": { "node": ">=22" },
  "scripts": {
    "build:contract": "compact compile --skip-zk contract/src/por.compact contract/managed",
    "test": "vitest run",
    "pretest": "pnpm build:contract",
    "browser:dev": "pnpm --dir browser dev",
    "browser:build": "pnpm --dir browser build",
    "browser:build:zk": "pnpm --dir browser build:zk",
    "browser:deploy": "pnpm --dir browser deploy:netlify"
  },
  "dependencies": {
    "@midnight-ntwrk/compact-runtime": "0.16.0",
    "@midnight-ntwrk/onchain-runtime-v3": "*",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "typescript": "^5.6.0",
    "vitest": "^3.2.6"
  }
}
